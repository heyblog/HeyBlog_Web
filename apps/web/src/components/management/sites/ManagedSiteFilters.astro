---
import type { ListOption } from './managed-site-list.shared';

type Props = {
  keyword: string;
  classificationStatus: string;
  accessScope: string;
  siteStatus: string;
  isShow: string;
  recommend: string;
  mainTagId: string;
  mainTagOptions: Array<{ id: string; name: string }>;
  classificationOptions: ListOption[];
  accessScopeOptions: ListOption[];
  siteStatusOptions: ListOption[];
  booleanFilterOptions: ListOption[];
  clearHref: string;
};

const {
  keyword,
  classificationStatus,
  accessScope,
  siteStatus,
  isShow,
  recommend,
  mainTagId,
  mainTagOptions,
  classificationOptions,
  accessScopeOptions,
  siteStatusOptions,
  booleanFilterOptions,
  clearHref,
} = Astro.props;
---

<form class="space-y-4" method="get">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-end">
    <label class="min-w-0 flex-1 space-y-1">
      <span class="text-xs text-[var(--color-fg-3)]">关键词</span>
      <div class="relative" data-keyword-field>
        <input
          class="h-[42px] w-full rounded-[var(--radius-sm)] border border-[var(--color-line-med)] px-3 py-2 pr-10 text-sm"
          name="q"
          placeholder="按站点名、URL 或 BID 搜索"
          type="text"
          value={keyword}
        />
        <button
          class="absolute right-2 top-1/2 inline-flex h-7 w-7 -translate-y-1/2 items-center justify-center rounded-full text-base leading-none text-[var(--color-fg-3)] transition hover:bg-[var(--color-bg)] hover:text-[var(--color-fg)]"
          type="button"
          aria-label="清空关键词"
          onclick="const wrapper = this.closest('[data-keyword-field]'); const input = wrapper?.querySelector('input[name=q]'); if (input instanceof HTMLInputElement) { input.value = ''; input.focus(); }"
        >
          ×
        </button>
      </div>
    </label>

    <button class="action-button action-button-secondary shrink-0 sm:min-w-28" type="submit">
      搜索站点
    </button>
  </div>

  <div
    class="rounded-[var(--radius-sm)] border border-[var(--color-line)] bg-[var(--color-bg-raised)] p-4 grid gap-x-3 gap-y-2 grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-[repeat(6,minmax(0,1fr))_auto] lg:items-end"
  >
    <label class="space-y-1">
      <span class="text-xs text-[var(--color-fg-3)]">主分类</span>
      <select
        class="h-[42px] w-full rounded-[var(--radius-sm)] border border-[var(--color-line-med)] px-3 py-2 text-sm"
        name="main_tag_id"
      >
        <option value="">全部主分类</option>
        {
          mainTagOptions.map((item) => (
            <option value={item.id} selected={mainTagId === item.id}>
              {item.name}
            </option>
          ))
        }
      </select>
    </label>

    <label class="space-y-1">
      <span class="text-xs text-[var(--color-fg-3)]">分类状态</span>
      <select
        class="h-[42px] w-full rounded-[var(--radius-sm)] border border-[var(--color-line-med)] px-3 py-2 text-sm"
        name="classification_status"
      >
        <option value="">全部分类状态</option>
        {
          classificationOptions.map((item) => (
            <option value={item.value} selected={classificationStatus === item.value}>
              {item.label}
            </option>
          ))
        }
      </select>
    </label>

    <label class="space-y-1">
      <span class="text-xs text-[var(--color-fg-3)]">访问范围</span>
      <select
        class="h-[42px] w-full rounded-[var(--radius-sm)] border border-[var(--color-line-med)] px-3 py-2 text-sm"
        name="access_scope"
      >
        <option value="">全部访问范围</option>
        {
          accessScopeOptions.map((item) => (
            <option value={item.value} selected={accessScope === item.value}>
              {item.label}
            </option>
          ))
        }
      </select>
    </label>

    <label class="space-y-1">
      <span class="text-xs text-[var(--color-fg-3)]">站点状态</span>
      <select
        class="h-[42px] w-full rounded-[var(--radius-sm)] border border-[var(--color-line-med)] px-3 py-2 text-sm"
        name="status"
      >
        <option value="">全部站点状态</option>
        {
          siteStatusOptions.map((item) => (
            <option value={item.value} selected={siteStatus === item.value}>
              {item.label}
            </option>
          ))
        }
      </select>
    </label>

    <label class="space-y-1">
      <span class="text-xs text-[var(--color-fg-3)]">前台显示</span>
      <select
        class="h-[42px] w-full rounded-[var(--radius-sm)] border border-[var(--color-line-med)] px-3 py-2 text-sm"
        name="is_show"
      >
        <option value="">全部</option>
        {
          booleanFilterOptions.map((item) => (
            <option value={item.value} selected={isShow === item.value}>
              {item.label}
            </option>
          ))
        }
      </select>
    </label>

    <label class="space-y-1">
      <span class="text-xs text-[var(--color-fg-3)]">推荐站点</span>
      <select
        class="h-[42px] w-full rounded-[var(--radius-sm)] border border-[var(--color-line-med)] px-3 py-2 text-sm"
        name="recommend"
      >
        <option value="">全部</option>
        {
          booleanFilterOptions.map((item) => (
            <option value={item.value} selected={recommend === item.value}>
              {item.label}
            </option>
          ))
        }
      </select>
    </label>

    <div
      class="flex items-end gap-3 sm:col-span-3 md:col-span-2 lg:col-span-1 lg:justify-end mt-3 md:mt-0"
    >
      <button class="action-button action-button-secondary w-28" type="submit"> 应用筛选 </button>
      <a class="action-button action-button-ghost w-28" href={clearHref}>清空</a>
    </div>
  </div>
</form>
