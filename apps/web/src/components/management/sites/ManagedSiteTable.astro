---
import {
  formatManagedSiteUpdateTime,
  type ListOption,
  type ManagedSiteListItem,
  type PaginationView,
  readManagedSiteFlags,
  readOptionLabel,
} from './managed-site-list.shared';

type Props = {
  items: ManagedSiteListItem[];
  classificationOptions: ListOption[];
  accessScopeOptions: ListOption[];
  siteStatusOptions: ListOption[];
  paginationView: PaginationView;
};

const { items, classificationOptions, accessScopeOptions, siteStatusOptions, paginationView } =
  Astro.props;
---

<div class="mt-5 overflow-x-auto rounded-[var(--radius-sm)] border border-[var(--color-line)]">
  <table class="min-w-full border-collapse text-left text-sm">
    <thead class="border-b border-[var(--color-line)] bg-[var(--color-bg-raised)]">
      <tr>
        <th class="px-4 py-3 align-middle font-medium">站点</th>
        <th class="px-4 py-3 align-middle font-medium">信息</th>
        <th class="px-4 py-3 align-middle font-medium">最近更新</th>
        <th class="px-4 py-3 align-middle font-medium">操作</th>
      </tr>
    </thead>
    <tbody>
      {
        items.length > 0 ? (
          items.map((entry) => (
            <tr class="border-b border-(--color-line) last:border-b-0">
              <td class="px-4 py-4 align-middle">
                <div class="mt-1 text-xs text-(--color-fg-3)">BID: {entry.bid ?? '—'}</div>
                <div class="mt-1 not-[]:font-medium">{entry.name}</div>
                <div class="mt-1 text-xs text-(--color-fg-3)">{entry.url}</div>
                <div class="mt-1 text-xs text-(--color-fg-3)">{entry.id}</div>
                <div class="mt-1 text-xs text-(--color-fg-3)">{readManagedSiteFlags(entry)}</div>
              </td>
              <td class="px-4 py-4 align-middle">
                <div class="grid gap-x-4 gap-y-1 text-xs text-[var(--color-fg-3)] sm:grid-cols-2">
                  <div>主分类：{entry.main_tag_name ?? '—'}</div>
                  <div>
                    分类状态：
                    {readOptionLabel(classificationOptions, entry.classification_status)}
                  </div>
                  <div>访问范围：{readOptionLabel(accessScopeOptions, entry.access_scope)}</div>
                  <div>站点状态：{readOptionLabel(siteStatusOptions, entry.status)}</div>
                </div>
              </td>
              <td class="px-4 py-4 align-middle text-xs text-[var(--color-fg-3)]">
                {formatManagedSiteUpdateTime(entry.update_time)}
              </td>
              <td class="px-4 py-4 align-middle">
                <a
                  class="inline-flex items-center rounded-[var(--radius-sm)] border border-[var(--color-line-med)] px-3 py-1.5 text-xs font-medium"
                  href={`/management/sites/${entry.id}`}
                >
                  编辑站点
                </a>
              </td>
            </tr>
          ))
        ) : (
          <tr>
            <td class="px-4 py-10 text-center text-[var(--color-fg-3)]" colspan="4">
              暂无符合条件的站点记录。
            </td>
          </tr>
        )
      }
    </tbody>
  </table>
</div>

{
  items.length > 0 && (
    <div class="mt-6 flex flex-wrap items-center justify-between gap-4 border-t border-(--color-line) pt-6">
      <p class="text-sm text-(--color-fg-3)">
        第 {paginationView.page} / {paginationView.totalPages} 页，共 {paginationView.totalItems} 条
      </p>
      <div class="action-row">
        {paginationView.previousHref ? (
          <a class="action-button action-button-ghost" href={paginationView.previousHref}>
            上一页
          </a>
        ) : (
          <span class="action-button action-button-ghost" aria-disabled="true">
            上一页
          </span>
        )}

        {paginationView.pages.map((pageItem) =>
          pageItem.isCurrent ? (
            <span class="action-button action-button-primary" aria-current="page">
              {pageItem.page}
            </span>
          ) : (
            <a class="action-button action-button-secondary" href={pageItem.href}>
              {pageItem.page}
            </a>
          ),
        )}

        {paginationView.nextHref ? (
          <a class="action-button action-button-ghost" href={paginationView.nextHref}>
            下一页
          </a>
        ) : (
          <span class="action-button action-button-ghost" aria-disabled="true">
            下一页
          </span>
        )}
      </div>
    </div>
  )
}
