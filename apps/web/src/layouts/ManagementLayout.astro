---
import {
  hasAnyManagementPermission,
  hasManagementPermission,
  MANAGEMENT_NAV_ITEMS,
  type SessionUser,
} from '@/application/auth/auth.guard';
import BaseLayout from '@/layouts/BaseLayout.astro';

interface Props {
  title: string;
  currentPath: string;
  eyebrow?: string;
  heading: string;
}

const { title, currentPath, eyebrow = 'management / panel', heading } = Astro.props;
const user = Astro.locals.authUser as SessionUser | null | undefined;
const visibleNavItems =
  user?.role === 'SYS_ADMIN'
    ? MANAGEMENT_NAV_ITEMS
    : MANAGEMENT_NAV_ITEMS.filter((item) => hasManagementPermission(user, item.permission));
const showEmptyBanner = user?.role === 'ADMIN' && !hasAnyManagementPermission(user);
---

<BaseLayout title={`${title} | 集博栈 - zhblogs`} showFooter={false}>
  <main class="page-shell management-shell">
    <section class="page-stack">
      <div class="management-frame">
        <aside class="management-sidebar">
          <details class="sidebar-collapsible management-sidebar-panel">
            <summary class="sidebar-collapsible-toggle">
              <span class="management-collapsible-summary-copy">
                <span class="sidebar-collapsible-title">管理菜单</span>
                <span class="management-collapsible-summary-note">
                  查看账号信息、快捷入口与可访问的管理模块。
                </span>
              </span>
              <span aria-hidden="true" class="sidebar-collapsible-icon">⌄</span>
            </summary>

            <div class="sidebar-collapsible-body">
              <div class="space-y-3">
                <p class="eyebrow">
                  <span class="status-dot" style="--status-dot: var(--color-info-dot)"></span>
                  management / identity
                </p>
                <div>
                  <div class="text-lg font-medium">{user?.nickname ?? '管理员'}</div>
                  <p class="mt-1 text-sm text-(--color-fg-3)">{user?.email ?? 'unknown'}</p>
                </div>
                <dl class="space-y-2 text-sm">
                  <div class="flex items-center justify-between gap-3">
                    <dt class="text-(--color-fg-3)">角色</dt>
                    <dd class="font-medium">{user?.role ?? 'UNKNOWN'}</dd>
                  </div>
                  <div class="flex items-center justify-between gap-3">
                    <dt class="text-(--color-fg-3)">会话版本</dt>
                    <dd class="font-medium">{user?.authVersion ?? '—'}</dd>
                  </div>
                </dl>
              </div>

              <div class="management-sidebar-actions">
                <a class="action-button action-button-secondary w-full" href="/"> 返回首页 </a>
                <a class="action-button action-button-primary w-full" href="/dashboard">
                  返回工作台
                </a>
                <form action="/auth/logout" method="post">
                  <button class="action-button action-button-ghost w-full" type="submit">
                    退出登录
                  </button>
                </form>
              </div>

              <nav class="management-sidebar-nav" aria-label="管理模块">
                <a
                  class:list={[
                    'management-sidebar-link rounded-sm border px-3 py-3 transition',
                    currentPath === '/management'
                      ? 'border-(--color-line-med) bg-(--color-bg-raised)'
                      : 'border-(--color-line) hover:border-(--color-line-med)',
                  ]}
                  href="/management"
                >
                  <div class="text-sm font-medium">管理首页</div>
                  <p class="mt-1 text-xs text-(--color-fg-3)">查看管理模块与快捷入口</p>
                </a>
                {
                  visibleNavItems.map((item) => (
                    <a
                      class:list={[
                        'management-sidebar-link rounded-sm border px-3 py-3 transition',
                        currentPath === item.href
                          ? 'border-(--color-line-med) bg-(--color-bg-raised)'
                          : 'border-(--color-line) hover:border-(--color-line-med)',
                      ]}
                      href={item.href}
                    >
                      <div class="text-sm font-medium">{item.label}</div>
                      <p class="mt-1 text-xs text-(--color-fg-3)">{item.description}</p>
                    </a>
                  ))
                }
              </nav>
            </div>
          </details>
        </aside>

        <div class="management-content space-y-6">
          {
            showEmptyBanner && (
              <div
                class="status-panel status-panel-warning flex items-start justify-between gap-4"
                data-management-empty-banner
              >
                <div>
                  <p class="eyebrow">
                    <span class="status-dot" style="--status-dot: var(--color-warn-dot)" />
                    management / pending authorization
                  </p>
                  <p class="mt-2 text-sm leading-7">
                    你已是管理员，但尚未获得模块权限，请联系相关管理员授权。
                  </p>
                </div>
                <button
                  class="action-button action-button-ghost h-9 w-9 px-0 text-sm"
                  data-management-empty-banner-close
                  type="button"
                >
                  ×
                </button>
              </div>
            )
          }

          <div class="surface-card page-lead">
            <div class="section-head">
              <div>
                <p class="eyebrow">
                  <span class="status-dot" style="--status-dot: var(--color-info-dot)"></span>
                  {eyebrow}
                </p>
                <h1 class="page-lead-title mt-4">{heading}</h1>
              </div>
            </div>
          </div>

          <slot />
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  const storageKey = 'zhblogs-management-empty-banner-dismissed';
  const banner = document.querySelector('[data-management-empty-banner]');
  const closeButton = document.querySelector('[data-management-empty-banner-close]');
  const sidebarMenus = document.querySelectorAll('.management-shell .management-sidebar-panel');
  const desktopMenuQuery = window.matchMedia('(min-width: 80rem)');

  const syncSidebarMenuState = () => {
    sidebarMenus.forEach((node) => {
      if (!(node instanceof HTMLDetailsElement)) {
        return;
      }

      if (desktopMenuQuery.matches) {
        node.open = true;
        return;
      }

      if (!desktopMenuQuery.matches) {
        node.open = false;
      }
    });
  };

  syncSidebarMenuState();
  desktopMenuQuery.addEventListener('change', syncSidebarMenuState);

  if (banner instanceof HTMLElement) {
    if (window.localStorage.getItem(storageKey) === 'true') {
      banner.style.display = 'none';
    }

    closeButton?.addEventListener('click', () => {
      window.localStorage.setItem(storageKey, 'true');
      banner.style.display = 'none';
    });
  }
</script>
