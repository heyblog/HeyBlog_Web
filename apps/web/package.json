{
  "name": "heyblog-web",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --config ./prettier.config.ts --write \"package.json\" \"*.ts\" \"src/**/*.{ts,js,astro,svelte,css}\"",
    "format:check": "prettier --config ./prettier.config.ts --check \"package.json\" \"*.ts\" \"src/**/*.{ts,js,astro,svelte,css}\"",
    "lint": "pnpm run lint:eslint && pnpm run stylelint",
    "lint:fix": "pnpm run lint:eslint:fix && pnpm run stylelint:fix",
    "lint:eslint": "eslint --config ./eslint.config.ts \"src/**/*.{ts,js,astro,svelte}\" \"*.ts\"",
    "lint:eslint:fix": "eslint --config ./eslint.config.ts \"src/**/*.{ts,js,astro,svelte}\" \"*.ts\" --fix",
    "stylelint": "stylelint --config ./stylelint.config.ts \"src/**/*.{css,astro,svelte}\"",
    "stylelint:fix": "stylelint --config ./stylelint.config.ts --fix \"src/**/*.{css,astro,svelte}\"",
    "typecheck": "astro check"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/partytown": "^2.1.7",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/svelte": "^9.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "@heyblog/configs": "workspace:*",
    "astro": "^7.0.9",
    "svelte": "^5.56.4",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  }
}
