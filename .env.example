# zhblogs environment template
# 规则：
# - 根目录脚本通过 scripts/run-with-env.mjs 加载 .env.dev/.env.test/.env.prod。
# - Docker 容器访问宿主机服务时使用 host.docker.internal；compose 已配置 host-gateway。
# - Cloudflare 生产密钥仍需同步到 Cloudflare Workers secrets。

# ============================================================
# 必需变量 / 共用
# 来源：
# - apps/api/src/infrastructure/app/http/app-config.service.ts
# - apps/worker/src/config/config.go
# - packages/db/src/client.ts
# - packages/db/drizzle.config.ts
# ============================================================

NODE_ENV=development
DATABASE_URL=postgresql://postgres:password@localhost:5432/zhblogs
VALKEY_URL=valkey://localhost:6379


# ============================================================
# 必需变量 / apps/api
# 来源：apps/api/src/infrastructure/app/http/app-config.service.ts
# ============================================================

API_GITHUB_CLIENT_ID=github-client-id
API_GITHUB_CLIENT_SECRET=github-client-secret
API_GITHUB_CALLBACK_URL=http://127.0.0.1:9101/auth/github/callback
API_GITHUB_SCOPE=read:user,user:email
API_SMTP_HOST=smtp.example.com
API_SMTP_PORT=587
API_SMTP_SECURE=false
API_SMTP_USER=smtp-user
API_SMTP_PASS=smtp-password
API_SMTP_FROM=noreply@example.com


# ============================================================
# 必需变量 / apps/cloudflare
# 来源：
# - apps/cloudflare/src/index.ts
# - apps/cloudflare/src/types.ts
# ============================================================

CHECKER_TOKEN=dev-checker-token


# ============================================================
# 可选变量 / 共用
# 来源：
# - apps/worker/src/config/config.go
# - apps/cloudflare/src/index.ts
# ============================================================

WORKER_CALLBACK_SECRET=dev-checker-token


# ============================================================
# 可选变量 / apps/api
# 来源：
# - apps/api/src/infrastructure/app/http/app-config.service.ts
# - apps/api/src/shared/runtime/service/app-logger.service.ts
# ============================================================

API_PORT=9201
API_LOG_LEVEL=debug
API_LOG_DIR=./logs
API_WEB_BASE_URL=http://127.0.0.1:9101
API_CORS_ORIGINS=http://127.0.0.1:4321,http://localhost:4321,http://127.0.0.1:9101,http://localhost:9101
API_COOKIE_DOMAIN=
API_JWT_ACCESS_SECRET=zhblogs-api-access-secret-for-dev-and-test-only
API_JWT_REFRESH_SECRET=zhblogs-api-refresh-secret-for-dev-and-test-only
API_JWT_ACCESS_TTL_SECONDS=21600
API_JWT_REFRESH_TTL_SECONDS=604800
API_INTERNAL_TOKEN=zhblogs-internal-dev-token


# ============================================================
# 可选变量 / apps/web
# 来源：
# - apps/web/src/env.d.ts
# - apps/web/src/application/auth/auth.server.ts
# - apps/web/src/application/management/task-management.browser.ts
# ============================================================

PUBLIC_API_BASE_URL=http://127.0.0.1:9201
WEB_PORT=9101


# ============================================================
# 可选变量 / apps/worker
# 来源：apps/worker/src/config/config.go
# ============================================================

WORKER_ID=
WORKER_PORT=9301
WORKER_POLL_INTERVAL_MS=2000
WORKER_SCHEDULE_INTERVAL_MS=5000
WORKER_CONSUME_BATCH=1
WORKER_CONSUME_CONCURRENCY=4
WORKER_SCHEDULE_BATCH=50
WORKER_JOB_HEARTBEAT_INTERVAL_MS=5000
WORKER_JOB_HEARTBEAT_TIMEOUT_MS=45000
WORKER_JOB_RETRY_LIMIT=2
WORKER_JOB_RETRY_DELAY_MS=5000
WORKER_SITE_CHECK_BATCH_CONCURRENCY=4
WORKER_RSS_FETCH_BATCH_CONCURRENCY=4
WORKER_HEALTH_BACKLOG_MAX=500
WORKER_HEALTH_NO_SUCCESS_MS=1800000
WORKER_CALLBACK_URL=http://127.0.0.1:9501
WORKER_CALLBACK_TIMEOUT_MS=5000
WORKER_API_BASE_URL=http://127.0.0.1:9201
WORKER_API_INTERNAL_TOKEN=zhblogs-internal-dev-token
WORKER_API_TIMEOUT_MS=5000
TZ=Asia/Shanghai


# ============================================================
# 可选变量 / apps/cloudflare
# 来源：
# - apps/cloudflare/src/index.ts
# - apps/cloudflare/wrangler.jsonc
# ============================================================

CLOUDFLARE_LOAD_DEV_VARS_FROM_DOT_ENV=true


# ============================================================
# 可选变量 / tests and CI
# 来源：
# - apps/web/playwright.config.ts
# - apps/web/tests/setup/env.ts
# - .github/workflows/main.yml
# ============================================================

CI=
PORT=
PLAYWRIGHT_WEB_PORT=9101
PLAYWRIGHT_WEB_BASE_URL=http://127.0.0.1:9101
IMAGE_TAG=local
